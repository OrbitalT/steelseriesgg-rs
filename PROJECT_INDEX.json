{
	"project": {
		"name": "steelseriesgg-rs",
		"version": "0.1.0",
		"description": "A complete open-source SteelSeries GG replacement for Linux",
		"repository": "https://github.com/Ven0m0/steelseriesgg-rs",
		"license": "MIT",
		"language": "Rust",
		"edition": "2021",
		"generated": "2026-01-20"
	},
	"binaries": [
		{
			"name": "ssgg",
			"path": "src/main.rs",
			"type": "CLI",
			"description": "Main SteelSeries GG replacement binary"
		},
		{
			"name": "discover_actuation",
			"path": "src/bin/discover_actuation.rs",
			"type": "utility",
			"description": "Device capability discovery tool"
		},
		{
			"name": "sonar_control",
			"path": "src/bin/sonar_control.rs",
			"type": "utility",
			"description": "SonarClient control utility",
			"requiredFeatures": ["sonar"]
		}
	],
	"library": {
		"name": "steelseries_gg",
		"path": "src/lib.rs",
		"description": "Rust library for SteelSeries hardware integration"
	},
	"modules": {
		"devices": {
			"path": "src/devices/",
			"description": "Hardware discovery and HID communication",
			"exports": [
				"Device (trait)",
				"DeviceManager",
				"DeviceInfo",
				"DeviceType",
				"HidReportBuilder"
			],
			"submodules": [
				"discovery",
				"hid_reports",
				"diagnostics",
				"key_mapping",
				"zone_mapping",
				"keyboards",
				"headsets"
			]
		},
		"rgb": {
			"path": "src/rgb/",
			"description": "Color representation and lighting effects",
			"exports": [
				"Color",
				"Effect",
				"EffectEngine",
				"RgbController",
				"PerKeyRgbController"
			],
			"effects": [
				"Static",
				"Breathing",
				"Spectrum",
				"Wave",
				"Reactive",
				"Gradient",
				"Custom",
				"Off"
			]
		},
		"gamesense": {
			"path": "src/gamesense/",
			"description": "GameSense HTTP server for game integration",
			"exports": ["GameMetadata", "GameEvent", "GamesenseServer"],
			"submodules": ["server", "handlers"],
			"port": 27301
		},
		"performance": {
			"path": "src/performance.rs",
			"description": "Real-time performance monitoring and statistics",
			"exports": [
				"PerformanceManager",
				"PerformanceStats",
				"PerformanceMonitor"
			]
		},
		"validation": {
			"path": "src/validation.rs",
			"description": "Resource validation and leak detection",
			"exports": ["RgbValidator", "ValidationResult"]
		},
		"profiles": {
			"path": "src/profiles/",
			"description": "Configuration persistence",
			"exports": ["Profile"],
			"storagePath": "~/.config/ssgg/profiles/"
		},
		"audio": {
			"path": "src/audio/",
			"description": "Audio mixing and Sonar integration",
			"exports": ["AudioMixer", "SonarClient"],
			"feature": "audio"
		},
		"config": {
			"path": "src/config/",
			"description": "Configuration management",
			"exports": ["Config"]
		},
		"pollrate": {
			"path": "src/pollrate.rs",
			"description": "USB poll rate control",
			"supportedRates": [125, 250, 500, 1000, 2000, 4000]
		},
		"error": {
			"path": "src/error.rs",
			"description": "Error types and handling"
		},
		"device_state": {
			"path": "src/device_state.rs",
			"description": "Daemon state management"
		}
	},
	"constants": {
		"STEELSERIES_VENDOR_ID": "0x1038",
		"KEYBOARD_REPORT_SIZE": 641,
		"HEADSET_REPORT_SIZE": 65,
		"MAX_RGB_ZONES": 9,
		"CACHE_THRESHOLD_MS": 16,
		"GAMESENSE_DEFAULT_PORT": 27301
	},
	"dependencies": [
		{
			"name": "axum",
			"version": "0.8",
			"purpose": "HTTP server"
		},
		{
			"name": "tokio",
			"version": "1.49",
			"purpose": "Async runtime"
		},
		{
			"name": "hidapi",
			"version": "2.6.4",
			"purpose": "USB HID communication"
		},
		{
			"name": "clap",
			"version": "4.5",
			"purpose": "CLI argument parsing"
		},
		{
			"name": "serde",
			"version": "1.0",
			"purpose": "Serialization"
		},
		{
			"name": "toml",
			"version": "0.9",
			"purpose": "TOML parsing"
		},
		{
			"name": "tracing",
			"version": "0.1",
			"purpose": "Logging"
		},
		{
			"name": "thiserror",
			"version": "2.0",
			"purpose": "Error handling"
		},
		{
			"name": "libpulse-binding",
			"version": "2.30.1",
			"purpose": "PulseAudio integration",
			"optional": true,
			"feature": "audio"
		},
		{
			"name": "reqwest",
			"version": "0.13",
			"purpose": "HTTP client",
			"optional": true,
			"feature": "sonar"
		}
	],
	"features": {
		"default": {
			"description": "Minimal features",
			"includes": []
		},
		"audio": {
			"description": "PulseAudio integration",
			"dependencies": ["libpulse-binding"]
		},
		"sonar": {
			"description": "SteelSeries Sonar API client",
			"dependencies": ["reqwest"],
			"implies": ["audio"]
		}
	},
	"tests": {
		"total": 66,
		"modules": {
			"rgb": 15,
			"profiles": 10,
			"performance": 8,
			"gamesense": 6,
			"pollrate": 4,
			"hid_reports": 12,
			"device_discovery": 8,
			"validation": 5
		}
	},
	"buildProfiles": {
		"release": {
			"strip": true,
			"lto": "fat",
			"codegen-units": 1,
			"panic": "abort",
			"opt-level": 3,
			"binarySize": "2-3 MB"
		}
	},
	"documentation": {
		"CLAUDE.md": "Comprehensive developer guide for AI assistants",
		"README.md": "User documentation and getting started",
		"CONTRIBUTING.md": "Contribution guidelines",
		"PERFORMANCE_OPTIMIZATIONS.md": "Performance findings",
		"docs/development/OPTIMIZATION_REPORT.md": "Detailed optimization metrics",
		"docs/development/DEPENDENCY_AUDIT_REPORT.md": "Security audit",
		"docs/development/PROTOCOL_RESEARCH.md": "USB protocol documentation"
	},
	"codeStyle": {
		"indentation": "4 spaces",
		"lineLength": "100 characters max",
		"formatTool": "cargo fmt",
		"linter": "cargo clippy",
		"naming": {
			"functions": "snake_case",
			"types": "PascalCase",
			"constants": "SCREAMING_SNAKE_CASE"
		}
	},
	"performanceMetrics": {
		"cpuReduction": "20%",
		"binarySize": "2-3 MB (release, stripped)",
		"effectCacheThreshold": "16ms (60 FPS)"
	},
	"keyGotchas": [
		"Animated effects require daemon mode",
		"Use HidReportBuilder for correct sizes",
		"Apex Pro TKL 2023 uses Product ID 0x1628 (not 0x1618)",
		"Feature flag sonar requires audio",
		"Permissions require udev rules and input group"
	],
	"quickCommands": {
		"build": "cargo build --release",
		"test": "cargo test --all-features",
		"listDevices": "RUST_LOG=debug cargo run -- devices",
		"daemon": "cargo run --release -- daemon",
		"testRgb": "cargo run -- rgb --color red"
	}
}
