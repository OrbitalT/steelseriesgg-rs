	"quick_start": {
		"installation": [
			"git clone https://github.com/Ven0m0/steelseriesgg-rs.git",
			"cd steelseriesgg-rs",
			"sudo apt install libudev-dev libhidapi-dev libpulseaudio-dev",
			"cargo build --release --all-features",
