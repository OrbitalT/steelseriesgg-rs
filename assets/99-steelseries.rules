# /etc/udev/rules.d/99-steelseries.rules
# SteelSeries device permissions for user access
# Sources: apex-tux, apex7tkl_linux, steelseries-linux

# Generic input group access
SUBSYSTEM=="input", GROUP="input", MODE="0666"

# Vendor-wide USB and HID access
SUBSYSTEM=="input", GROUP="input", MODE="0660"

# Vendor-wide USB and HID access
SUBSYSTEM=="usb", ATTRS{idVendor}=="1038", GROUP="input", MODE="0660"
SUBSYSTEM=="hidraw", ATTRS{idVendor}=="1038", GROUP="input", MODE="0660"

# External script hook (requires steelseries-perms.py in same dir)
# ACTION=="add", SUBSYSTEM=="hidraw", ATTRS{idVendor}=="1038", RUN+="/etc/udev/rules.d/steelseries-perms.py '%E{DEVNAME}'"

# ── Apex Keyboards ──────────────────────────────────────────────
SUBSYSTEM=="hidraw", ATTRS{idVendor}=="1038", ATTRS{idProduct}=="1610", GROUP="input", MODE="0660"
SUBSYSTEM=="hidraw", ATTRS{idVendor}=="1038", ATTRS{idProduct}=="1612", GROUP="input", MODE="0660"
SUBSYSTEM=="hidraw", ATTRS{idVendor}=="1038", ATTRS{idProduct}=="1614", GROUP="input", MODE="0660"
SUBSYSTEM=="hidraw", ATTRS{idVendor}=="1038", ATTRS{idProduct}=="1616", GROUP="input", MODE="0660"
SUBSYSTEM=="hidraw", ATTRS{idVendor}=="1038", ATTRS{idProduct}=="1618", GROUP="input", MODE="0660"
SUBSYSTEM=="hidraw", ATTRS{idVendor}=="1038", ATTRS{idProduct}=="161a", GROUP="input", MODE="0660"
SUBSYSTEM=="hidraw", ATTRS{idVendor}=="1038", ATTRS{idProduct}=="161c", GROUP="input", MODE="0660"
